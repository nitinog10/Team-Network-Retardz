generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  FLEET_MANAGER
  SAFETY_MANAGER
  FINANCIAL_MANAGER
  DRIVER
}

enum VehicleStatus {
  AVAILABLE
  ON_TRIP
  IN_SHOP
  RETIRED
}

enum DriverStatus {
  AVAILABLE
  ON_TRIP
  OFF_DUTY
  SUSPENDED
}

enum VerificationStatus {
  UNVERIFIED
  PENDING
  VERIFIED
  FAILED
}

enum TripStatus {
  DRAFT
  DISPATCHED
  COMPLETED
  CANCELLED
}

enum MaintenanceStatus {
  OPEN
  CLOSED
}

enum ExpenseCategory {
  FUEL
  TOLL
  REPAIR
  PERMIT
  OTHER
}

model Organisation {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())

  users           User[]
  vehicles        Vehicle[]
  drivers         Driver[]
  trips           Trip[]
  maintenanceLogs MaintenanceLog[]
  fuelLogs        FuelLog[]
  expenses        Expense[]
  activityLogs    ActivityLog[]
}

model User {
  id             String   @id @default(cuid())
  organisationId String
  email          String   @unique
  name           String
  passwordHash   String
  role           Role
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organisation Organisation @relation(fields: [organisationId], references: [id])
  driver       Driver?

  @@index([organisationId, role])
}

model Vehicle {
  id                 String        @id @default(cuid())
  organisationId     String
  registrationNumber String
  type               String
  maxLoadKg          Int
  odometerKm         Int           @default(0)
  acquisitionCost    Decimal       @default(0) @db.Decimal(12, 2)
  region             String
  status             VehicleStatus @default(AVAILABLE)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  organisation    Organisation     @relation(fields: [organisationId], references: [id])
  trips           Trip[]
  maintenanceLogs MaintenanceLog[]
  fuelLogs        FuelLog[]
  expenses        Expense[]

  @@unique([organisationId, registrationNumber])
  @@index([organisationId, status])
}

model Driver {
  id                 String             @id @default(cuid())
  organisationId     String
  userId             String?            @unique
  name               String
  licenceNumber      String
  licenceCategory    String
  licenceExpiry      DateTime
  safetyScore        Int                @default(100)
  status             DriverStatus       @default(AVAILABLE)
  verificationStatus VerificationStatus @default(UNVERIFIED)
  verifiedAt         DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  organisation Organisation @relation(fields: [organisationId], references: [id])
  user         User?        @relation(fields: [userId], references: [id])
  trips        Trip[]

  @@index([organisationId, status])
}

model Trip {
  id                String     @id @default(cuid())
  organisationId    String
  tripNumber        String
  source            String
  destination       String
  vehicleId         String
  driverId          String
  cargoWeightKg     Int
  plannedDistanceKm Int
  actualDistanceKm  Int?
  finalOdometerKm   Int?
  revenue           Decimal    @default(0) @db.Decimal(12, 2)
  status            TripStatus @default(DRAFT)
  dispatchedAt      DateTime?
  completedAt       DateTime?
  cancelledAt       DateTime?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  organisation Organisation @relation(fields: [organisationId], references: [id])
  vehicle      Vehicle      @relation(fields: [vehicleId], references: [id])
  driver       Driver       @relation(fields: [driverId], references: [id])
  fuelLogs     FuelLog[]
  expenses     Expense[]

  @@unique([organisationId, tripNumber])
  @@index([organisationId, status])
}

model MaintenanceLog {
  id             String            @id @default(cuid())
  organisationId String
  vehicleId      String
  description    String
  status         MaintenanceStatus @default(OPEN)
  cost           Decimal           @default(0) @db.Decimal(12, 2)
  openedAt       DateTime          @default(now())
  closedAt       DateTime?

  organisation Organisation @relation(fields: [organisationId], references: [id])
  vehicle      Vehicle      @relation(fields: [vehicleId], references: [id])

  @@index([organisationId, status])
}

model FuelLog {
  id             String   @id @default(cuid())
  organisationId String
  vehicleId      String
  tripId         String?
  litres         Decimal  @db.Decimal(10, 2)
  cost           Decimal  @db.Decimal(12, 2)
  odometerKm     Int
  loggedAt       DateTime @default(now())

  organisation Organisation @relation(fields: [organisationId], references: [id])
  vehicle      Vehicle      @relation(fields: [vehicleId], references: [id])
  trip         Trip?        @relation(fields: [tripId], references: [id])

  @@index([organisationId, vehicleId])
}

model Expense {
  id             String          @id @default(cuid())
  organisationId String
  vehicleId      String?
  tripId         String?
  category       ExpenseCategory
  amount         Decimal         @db.Decimal(12, 2)
  notes          String?
  incurredAt     DateTime        @default(now())

  organisation Organisation @relation(fields: [organisationId], references: [id])
  vehicle      Vehicle?     @relation(fields: [vehicleId], references: [id])
  trip         Trip?        @relation(fields: [tripId], references: [id])

  @@index([organisationId, category])
}

model ActivityLog {
  id             String   @id @default(cuid())
  organisationId String
  actorId        String
  entityType     String
  entityId       String
  action         String
  metadata       Json?
  createdAt      DateTime @default(now())

  organisation Organisation @relation(fields: [organisationId], references: [id])

  @@index([organisationId, entityType, entityId])
}
